.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f7fa;
}

.upgrade-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.upgrade-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 48rpx 40rpx;
  text-align: center;
  width: 80%;
}

.upgrade-icon {
  font-size: 64rpx;
}

.upgrade-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin: 16rpx 0;
}

.upgrade-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.upgrade-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.messages-area {
  flex: 1;
  padding: 20rpx 24rpx;
  overflow-y: auto;
}

.welcome-msg {
  text-align: center;
  padding: 60rpx 40rpx;
}

.welcome-icon {
  font-size: 80rpx;
}

.welcome-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin: 16rpx 0;
}

.welcome-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 32rpx;
}

.welcome-suggestions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  align-items: center;
}

.suggestion-item {
  display: block;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 28rpx;
  font-size: 26rpx;
  color: #4a90d9;
  text-align: left;
  width: 90%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.message {
  display: flex;
  margin-bottom: 24rpx;
  align-items: flex-start;
}

.message.user {
  flex-direction: row-reverse;
}

.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #e8f0fe;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.message.user .msg-avatar {
  background: #d4edda;
}

.msg-content {
  max-width: 70%;
  margin: 0 16rpx;
}

.msg-text {
  display: block;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  word-break: break-all;
}

.message.user .msg-text {
  background: #4a90d9;
  color: #fff;
}

.msg-time {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  text-align: right;
}

.message.user .msg-time {
  text-align: left;
}

.typing-indicator {
  display: flex;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  width: fit-content;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ccc;
  animation: typing 1.4s infinite;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%, 60%, 100% { opacity: 0.3; transform: scale(0.8); }
  30% { opacity: 1; transform: scale(1); }
}

.remaining-bar {
  padding: 8rpx 24rpx;
  background: #fff8e1;
  text-align: center;
}

.remaining-text {
  font-size: 24rpx;
  color: #f5a623;
}

.input-area {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.chat-input {
  flex: 1;
  height: 72rpx;
  background: #f5f7fa;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}

.send-btn {
  margin-left: 16rpx;
  padding: 0 28rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #999;
  background: #f0f0f0;
}

.send-btn.active {
  background: #4a90d9;
  color: #fff;
}
