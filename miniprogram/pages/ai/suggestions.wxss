.suggestions-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 20rpx 24rpx;
}

.loading {
  text-align: center;
  padding: 120rpx 0;
}

.loading-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

.summary-card {
  background: linear-gradient(135deg, #4a90d9, #6bb5f0);
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: flex-start;
}

.summary-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.summary-text {
  font-size: 28rpx;
  color: #fff;
  line-height: 1.6;
  flex: 1;
}

.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.suggestion-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.suggestion-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.suggestion-priority {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  color: #fff;
}

.priority-high {
  background: #e74c3c;
}

.priority-medium {
  background: #f5a623;
}

.priority-low {
  background: #95a5a6;
}

.suggestion-category {
  font-size: 22rpx;
  color: #999;
  background: #f5f7fa;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.suggestion-title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.suggestion-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.empty {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.refresh-btn {
  text-align: center;
  padding: 32rpx;
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #4a90d9;
}
