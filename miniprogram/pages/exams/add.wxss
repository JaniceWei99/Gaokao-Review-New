.form-page {
  padding-bottom: 160rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.form-input {
  background-color: var(--color-card-bg);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: var(--font-base);
}

.form-picker {
  background-color: var(--color-card-bg);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  font-size: var(--font-base);
}

.subject-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.subject-chip {
  min-width: 120rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  font-size: var(--font-sm);
  padding: 0 28rpx;
}

.score-section {
  margin-top: 24rpx;
}

.score-item {
  background-color: var(--color-card-bg);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.score-header {
  margin-bottom: 16rpx;
}

.score-subject {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--color-text-primary);
}

.score-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.score-field {
  flex: 1;
}

.score-label {
  font-size: var(--font-xs);
  color: var(--color-text-hint);
  display: block;
  margin-bottom: 8rpx;
}

.score-input {
  background-color: var(--color-bg);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: 0 16rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: var(--font-md);
  text-align: center;
}

.score-divider {
  font-size: var(--font-lg);
  color: var(--color-text-hint);
  margin-top: 28rpx;
}
