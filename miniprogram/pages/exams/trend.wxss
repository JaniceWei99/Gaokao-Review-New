.trend-page {
  padding-bottom: 40rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.form-picker {
  background-color: var(--color-card-bg);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  font-size: var(--font-base);
}

.form-picker-placeholder {
  color: var(--color-text-hint);
}

.stats-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 20rpx;
  color: var(--color-text-hint);
}

.chart-card {
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.chart-title {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
  display: block;
}

.trend-canvas {
  width: 100%;
  height: 400rpx;
}

.table-header {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 2rpx solid var(--color-border);
  font-size: var(--font-sm);
  color: var(--color-text-hint);
}

.table-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-border);
  font-size: var(--font-sm);
}

.th-name, .td-name {
  flex: 2;
}

.th-score, .td-score {
  flex: 2;
  text-align: center;
}

.th-rate, .td-rate {
  flex: 1;
  text-align: right;
}
