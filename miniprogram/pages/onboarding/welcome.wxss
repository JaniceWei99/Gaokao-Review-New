.welcome-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 64rpx 48rpx;
}

.welcome-hero {
  text-align: center;
  margin-bottom: 80rpx;
}

.welcome-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.welcome-subtitle {
  font-size: var(--font-base);
  color: var(--color-text-secondary);
  margin-top: 16rpx;
}

.welcome-features {
  width: 100%;
  margin-bottom: 80rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.feature-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: var(--color-primary);
  margin-right: 20rpx;
  flex-shrink: 0;
}

.feature-text {
  font-size: var(--font-base);
  color: var(--color-text-primary);
}
