<view class="container action-page">
  <view wx:if="{{loading}}" class="loading-container">
    <text class="text-hint">加载中...</text>
  </view>

  <view wx:elif="{{!actionCard}}" class="empty-state">
    <text class="empty-state-text">暂无行动卡片</text>
    <text class="text-hint mt-16">该里程碑暂无行动建议</text>
  </view>

  <view wx:else>

    <view class="action-header">
      <view wx:if="{{milestone}}" class="milestone-info">
        <text class="h2">{{milestone.title}}</text>
        <view class="action-meta mt-8">
          <text class="text-hint">{{milestone.date_display}}</text>
          <text class="text-primary ml-16">{{milestone.relative}}</text>
        </view>
      </view>
      <view wx:if="{{timing}}" class="timing-badge">
        <text class="timing-text">{{timing === '15d_before' ? '15天前' : '3天前'}}</text>
      </view>
    </view>

    <view class="progress-section card mt-24">
      <view class="progress-header">
        <text class="h3">{{actionCard.title}}</text>
        <text class="progress-text">{{checkedIndexes.length}}/{{actionCard.action_items.length}}</text>
      </view>
      <view class="progress-bar mt-12">
        <view class="progress-fill" style="width: {{progress * 100}}%"></view>
      </view>
    </view>

    <view wx:if="{{actionCard.description}}" class="card mt-16">
      <text class="body-text">{{actionCard.description}}</text>
    </view>

    <view class="action-items card mt-16">
      <text class="h3 mb-16">行动清单</text>
      <view wx:for="{{actionCard.action_items}}" wx:key="index"
            class="action-item {{item.checked ? 'item-checked' : ''}}"
            data-index="{{index}}"
            bindtap="onToggleItem">
        <view class="checkbox {{item.checked ? 'checkbox-checked' : ''}}">
          <text wx:if="{{item.checked}}" class="checkbox-icon">✓</text>
        </view>
        <view class="item-content">
          <text class="item-title {{item.checked ? 'text-crossed' : ''}}">{{item.title || item.text || item}}</text>
          <text wx:if="{{item.description || item.desc}}" class="item-desc">{{item.description || item.desc}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{actionCard.footer_tip}}" class="card mt-16 footer-tip">
      <text class="text-secondary">{{actionCard.footer_tip}}</text>
    </view>

  </view>
</view>
