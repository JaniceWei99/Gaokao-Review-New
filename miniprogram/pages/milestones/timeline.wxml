<view class="container timeline-page">
  <view class="timeline-header flex-between">
    <view>
      <text class="h3">里程碑时间线</text>
      <text class="text-hint ml-8 source-tag" wx:if="{{source === 'local' && !isLoggedIn}}">本地</text>
    </view>
    <text class="btn-text" bindtap="onAddCustom">+ 自定义</text>
  </view>

  <!-- 未登录提示 -->
  <view wx:if="{{!isLoggedIn && milestones.length > 0}}" class="local-tip card">
    <text class="text-hint">当前为本地数据，登录后可同步到云端</text>
  </view>

  <view wx:if="{{loading}}" class="loading-container">
    <text class="text-hint">加载中...</text>
  </view>

  <view wx:elif="{{milestones.length === 0}}" class="empty-state">
    <text class="empty-state-text">暂无里程碑数据</text>
    <text class="text-hint mt-8" wx:if="{{!isLoggedIn}}">添加自定义里程碑，数据保存在本地</text>
  </view>

  <view wx:else class="timeline-list">
    <block wx:for="{{milestones}}" wx:key="id">
      <view wx:if="{{showPast || !item.is_past}}" class="timeline-item {{item.is_past ? 'timeline-past' : ''}} {{item.is_today ? 'timeline-today' : ''}} {{item.type === 'custom' ? 'timeline-custom' : ''}}"
            data-id="{{item.id}}" bindtap="onMilestoneTap">
        <view class="timeline-line-group">
          <view class="timeline-dot {{item.type === 'custom' ? 'dot-custom' : item.is_today ? 'dot-today' : item.is_past ? 'dot-past' : 'dot-future'}}"></view>
          <view wx:if="{{index < milestones.length - 1}}" class="timeline-line"></view>
        </view>
        <view class="timeline-content card {{item.type === 'custom' ? 'card-custom' : ''}}">
          <view class="flex-between">
            <text class="timeline-name">{{item.name}}</text>
            <view class="tag {{item.type === 'custom' ? 'tag-custom' : 'tag-outline'}}">
              {{item.type === 'custom' ? '自定义' : '系统'}}
            </view>
          </view>
          <view wx:if="{{item.description}}" class="timeline-desc">
            <text class="text-hint">{{item.description}}</text>
          </view>
          <view class="timeline-meta flex-between mt-8">
            <text class="text-hint">{{item.date_display}}</text>
            <text class="{{item.is_today ? 'text-primary text-bold' : item.is_past ? 'text-hint' : 'text-primary'}}">
              {{item.is_today ? '今天' : item.relative}}
            </text>
          </view>
          <view wx:if="{{item.type === 'custom'}}" class="timeline-actions mt-8">
            <view class="edit-link" catchtap="onEditMilestone" data-id="{{item.id}}">编辑</view>
            <view class="delete-link" catchtap="onDeleteMilestone" data-id="{{item.id}}">删除</view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view class="toggle-past" bindtap="onTogglePast">
    <text class="btn-text">{{showPast ? '隐藏已过去' : '显示已过去'}}</text>
  </view>
</view>
