<!-- pages/index/index.wxml — Homepage -->
<view class="container home-page">

  <!-- Subscribe Message Guide Banner -->
  <view wx:if="{{showSubscribeGuide}}" class="subscribe-guide card">
    <view class="subscribe-guide-content">
      <text class="subscribe-guide-text">开启里程碑提醒，不错过每个重要节点</text>
      <view class="subscribe-guide-actions">
        <text class="subscribe-guide-dismiss" bindtap="onDismissSubscribe">稍后</text>
        <text class="subscribe-guide-btn" bindtap="onRequestSubscribe">开启提醒</text>
      </view>
    </view>
  </view>

  <!-- Vision Banner (first visit) -->
  <view wx:if="{{showVisionBanner}}" class="card vision-banner">
    <view class="vision-content">
      <text class="vision-title">🎓 高考家长帮</text>
      <text class="vision-text">陪伴高考，让家长更从容。助力高考，做家长最稳的支撑。帮您记住每一个重要节点，记录每一次成长，让陪伴有据可依、有迹可循。</text>
    </view>
    <text class="vision-close" bindtap="onDismissVision">✕</text>
  </view>

  <!-- Daily Quote Card -->
  <view class="card quote-card">
    <view class="quote-text">{{quote || '每一天的努力，都是在为未来铺路。'}}</view>
    <view class="quote-source text-hint">{{quoteAuthor || ''}}</view>
    <view wx:if="{{subscription && subscription.plan === 'premium' && !personalizedQuote}}" class="ai-quote-btn" bindtap="onGenerateAIQuote">
      <text>✨ 生成专属金句</text>
    </view>
    <view wx:if="{{personalizedQuote}}" class="ai-quote-result">
      <view class="ai-quote-text">{{personalizedQuote.content}}</view>
      <view class="ai-quote-author text-hint">{{personalizedQuote.author || 'AI家长顾问'}}</view>
    </view>
  </view>

  <!-- Gaokao Countdown -->
  <view class="card countdown-card">
    <view class="countdown-sections">
      <view class="countdown-item" wx:if="{{nearestCountdown}}">
        <view class="countdown-label text-secondary">距{{nearestCountdown.title}}</view>
        <view class="countdown-days">
          <text class="countdown-number">{{nearestCountdown.days}}</text>
          <text class="countdown-unit">天</text>
        </view>
      </view>
      <view class="countdown-divider" wx:if="{{nearestCountdown && gaokaoCountdown}}"></view>
      <view class="countdown-item" wx:if="{{gaokaoCountdown}}">
        <view class="countdown-label text-secondary">距高考</view>
        <view class="countdown-days">
          <text class="countdown-number">{{gaokaoCountdown.days}}</text>
          <text class="countdown-unit">天</text>
        </view>
      </view>
    </view>
    <view class="countdown-empty" wx:if="{{!nearestCountdown && !gaokaoCountdown}}">
      <view class="countdown-empty-text text-hint">暂无近期考试安排</view>
      <navigator url="/pages/milestones/add-custom" class="countdown-empty-action">添加里程碑</navigator>
    </view>
    <view class="countdown-guide" wx:if="{{!nearestCountdown && gaokaoCountdown}}">
      <navigator url="/pages/milestones/add-custom" class="countdown-guide-link">添加自定义里程碑</navigator>
    </view>
  </view>

  <!-- Local Data Summary (未登录时显示) -->
  <view wx:if="{{hasLocalData}}" class="card local-data-summary">
    <view class="local-data-header flex-between">
      <text class="local-data-title">📦 本地数据</text>
      <navigator url="/pages/profile/index" class="local-data-sync-link">登录同步 →</navigator>
    </view>
    <view class="local-data-grid">
      <view class="local-data-item">
        <text class="local-data-value">{{localExamsCount}}</text>
        <text class="local-data-label">考试成绩</text>
      </view>
      <view class="local-data-item">
        <text class="local-data-value">{{localErrorsCount}}</text>
        <text class="local-data-label">错题记录</text>
      </view>
      <view class="local-data-item">
        <text class="local-data-value">{{localGrowthCount}}</text>
        <text class="local-data-label">成长记录</text>
      </view>
    </view>
    <view class="local-data-desc text-hint">共 {{localDataCount}} 条记录，登录后可同步到云端永不丢失</view>
  </view>

  <!-- Active Action Card or Upcoming Milestones -->
  <view class="card section-card" wx:if="{{activeActionCard}}">
    <view class="card-header">
      <text class="card-title">📋 {{activeActionCard.title}}</text>
    </view>
    <view class="card-body">
      <text class="body-text">{{activeActionCard.subtitle || ''}}</text>
      <view class="mt-16">
        <text class="btn btn-primary btn-sm" bindtap="onViewActionCard">查看准备清单</text>
      </view>
    </view>
  </view>

  <view class="card section-card" wx:elif="{{upcomingMilestones.length > 0}}">
    <view class="card-header">
      <text class="card-title">🗓️ 近期里程碑</text>
      <navigator url="/pages/milestones/timeline" class="btn-text">查看全部</navigator>
    </view>
    <view class="card-body">
      <view class="milestone-item" wx:for="{{upcomingMilestones}}" wx:key="id">
        <view class="milestone-dot active"></view>
        <view class="milestone-info">
          <text class="milestone-name">{{item.title}}</text>
          <text class="milestone-date text-hint">{{item.days_remaining}}天后</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Quick Entry Grid -->
  <view class="quick-entries">
    <view class="quick-entry-title h3">快捷入口</view>
    <view class="quick-grid">
      <navigator url="/pages/milestones/timeline" class="quick-item">
        <view class="quick-icon quick-icon-milestone">🎯</view>
        <text class="quick-label">里程碑</text>
      </navigator>
      <navigator url="/pages/errors/list" class="quick-item">
        <view class="quick-icon quick-icon-errors">📸</view>
        <text class="quick-label">错题本</text>
        <text class="quick-count" wx:if="{{localErrorsCount > 0 || errorNotesSummary.total > 0}}">{{localErrorsCount || errorNotesSummary.total}}道</text>
      </navigator>
      <navigator url="/pages/exams/add" class="quick-item">
        <view class="quick-icon quick-icon-exams">📊</view>
        <text class="quick-label">录入成绩</text>
      </navigator>
      <navigator url="/pages/growth/timeline" class="quick-item">
        <view class="quick-icon quick-icon-growth">🏆</view>
        <text class="quick-label">成长记录</text>
        <text class="quick-count" wx:if="{{localGrowthCount > 0 || growthRecordsCount > 0}}">{{localGrowthCount || growthRecordsCount}}个闪光时刻</text>
      </navigator>
      <navigator url="/pages/knowledge/browse" class="quick-item">
        <view class="quick-icon quick-icon-knowledge">📚</view>
        <text class="quick-label">知识浏览</text>
      </navigator>
    </view>
  </view>

  <!-- AI Features Section (premium) -->
  <view class="card ai-section" wx:if="{{subscription && subscription.plan === 'premium'}}">
    <view class="card-header">
      <text class="card-title">✨ AI智能助手</text>
    </view>
    <view class="ai-grid">
      <view class="ai-item" bindtap="onNavigateTo" data-url="/pages/ai/chat">
        <text class="ai-icon">🤖</text>
        <text class="ai-label">AI家长顾问</text>
      </view>
      <view class="ai-item" bindtap="onNavigateTo" data-url="/pages/ai/suggestions">
        <text class="ai-icon">💡</text>
        <text class="ai-label">行动建议</text>
      </view>
      <view class="ai-item" bindtap="onNavigateTo" data-url="/pages/ai/monthly-report">
        <text class="ai-icon">📊</text>
        <text class="ai-label">月度报告</text>
      </view>
      <view class="ai-item" bindtap="onNavigateTo" data-url="/pages/ai/chat-history">
        <text class="ai-icon">💬</text>
        <text class="ai-label">对话记录</text>
      </view>
    </view>
  </view>

  <!-- AI Upgrade Prompt (non-premium) -->
  <view class="card ai-upgrade-card" wx:if="{{subscription && subscription.plan !== 'premium'}}">
    <view class="ai-upgrade-content">
      <text class="ai-upgrade-icon">✨</text>
      <text class="ai-upgrade-title">解锁AI智能助手</text>
      <text class="ai-upgrade-desc">AI家长顾问、个性化行动建议、月度成长报告</text>
      <text class="btn btn-primary btn-sm" bindtap="onUpgradeToPremium">升级高级版</text>
    </view>
  </view>

  <!-- Add to Desktop Guide (standard+ only, not yet added) -->
  <view class="card desktop-guide" wx:if="{{showDesktopGuide}}">
    <view class="desktop-guide-content">
      <text class="desktop-guide-icon">📱</text>
      <text class="desktop-guide-text">把倒计时和金句放在手机桌面</text>
      <view class="desktop-guide-actions">
        <text class="btn btn-primary btn-sm" bindtap="onAddDesktop">添加到桌面</text>
        <text class="desktop-guide-dismiss" bindtap="onDismissDesktop">稍后再说</text>
      </view>
    </view>
  </view>

</view>
