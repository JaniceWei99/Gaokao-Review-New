<!-- pages/index/index.wxml — Homepage -->
<view class="container home-page">

  <!-- Subscribe Message Guide Banner -->
  <view wx:if="{{showSubscribeGuide}}" class="subscribe-guide card">
    <view class="subscribe-guide-content">
      <text class="subscribe-guide-text">开启里程碑提醒，不错过每个重要节点</text>
      <view class="subscribe-guide-actions">
        <text class="subscribe-guide-dismiss" bindtap="onDismissSubscribe">稍后</text>
        <text class="subscribe-guide-btn" bindtap="onRequestSubscribe">开启提醒</text>
      </view>
    </view>
  </view>

  <!-- Daily Quote Card -->
  <view class="card quote-card">
    <view class="quote-text">{{quote || '每一天的努力，都是在为未来铺路。'}}</view>
    <view class="quote-source text-hint">{{quoteAuthor || ''}}</view>
  </view>

  <!-- Gaokao Countdown -->
  <view class="card countdown-card">
    <view class="countdown-sections">
      <view class="countdown-item" wx:if="{{nearestCountdown}}">
        <view class="countdown-label text-secondary">距{{nearestCountdown.title}}</view>
        <view class="countdown-days">
          <text class="countdown-number">{{nearestCountdown.days}}</text>
          <text class="countdown-unit">天</text>
        </view>
      </view>
      <view class="countdown-divider" wx:if="{{nearestCountdown && gaokaoCountdown}}"></view>
      <view class="countdown-item" wx:if="{{gaokaoCountdown}}">
        <view class="countdown-label text-secondary">距高考</view>
        <view class="countdown-days">
          <text class="countdown-number">{{gaokaoCountdown.days}}</text>
          <text class="countdown-unit">天</text>
        </view>
      </view>
    </view>
    <view class="countdown-hint text-hint" wx:if="{{!nearestCountdown && !gaokaoCountdown}}">
      暂无近期考试安排
    </view>
  </view>

  <!-- Active Action Card or Upcoming Milestones -->
  <view class="card section-card" wx:if="{{activeActionCard}}">
    <view class="card-header">
      <text class="card-title">📋 {{activeActionCard.title}}</text>
    </view>
    <view class="card-body">
      <text class="body-text">{{activeActionCard.subtitle || ''}}</text>
      <view class="mt-16">
        <text class="btn btn-primary btn-sm" bindtap="onViewActionCard">查看准备清单</text>
      </view>
    </view>
  </view>

  <view class="card section-card" wx:elif="{{upcomingMilestones.length > 0}}">
    <view class="card-header">
      <text class="card-title">🗓️ 近期里程碑</text>
      <navigator url="/pages/milestones/timeline" class="btn-text">查看全部</navigator>
    </view>
    <view class="card-body">
      <view class="milestone-item" wx:for="{{upcomingMilestones}}" wx:key="id">
        <view class="milestone-dot active"></view>
        <view class="milestone-info">
          <text class="milestone-name">{{item.title}}</text>
          <text class="milestone-date text-hint">{{item.days_remaining}}天后</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Quick Entry Grid -->
  <view class="quick-entries">
    <view class="quick-entry-title h3">快捷入口</view>
    <view class="quick-grid">
      <navigator url="/pages/errors/list" class="quick-item">
        <view class="quick-icon quick-icon-errors">📸</view>
        <text class="quick-label">错题本</text>
        <text class="quick-count" wx:if="{{errorNotesSummary.total > 0}}">{{errorNotesSummary.total}}道</text>
      </navigator>
      <navigator url="/pages/exams/add" class="quick-item">
        <view class="quick-icon quick-icon-exams">📊</view>
        <text class="quick-label">录入成绩</text>
      </navigator>
      <navigator url="/pages/growth/timeline" class="quick-item">
        <view class="quick-icon quick-icon-growth">🏆</view>
        <text class="quick-label">成长记录</text>
        <text class="quick-count" wx:if="{{growthRecordsCount > 0}}">{{growthRecordsCount}}个闪光时刻</text>
      </navigator>
      <navigator url="/pages/knowledge/browse" class="quick-item">
        <view class="quick-icon quick-icon-knowledge">📚</view>
        <text class="quick-label">知识浏览</text>
      </navigator>
    </view>
  </view>

  <!-- Add to Desktop Guide (standard+ only, not yet added) -->
  <view class="card desktop-guide" wx:if="{{showDesktopGuide}}">
    <view class="desktop-guide-content">
      <text class="desktop-guide-icon">📱</text>
      <text class="desktop-guide-text">把倒计时和金句放在手机桌面</text>
      <view class="desktop-guide-actions">
        <text class="btn btn-primary btn-sm" bindtap="onAddDesktop">添加到桌面</text>
        <text class="desktop-guide-dismiss" bindtap="onDismissDesktop">稍后再说</text>
      </view>
    </view>
  </view>

</view>
