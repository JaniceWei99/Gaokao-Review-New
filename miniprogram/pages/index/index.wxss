/* pages/index/index.wxss — Homepage styles */

.home-page {
  padding-bottom: 40rpx;
}

/* Subscribe Guide Banner */
.subscribe-guide {
  background: linear-gradient(135deg, #fff7e6, #fff1cc);
  border: 2rpx solid #ffd666;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.subscribe-guide-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.subscribe-guide-text {
  font-size: 26rpx;
  color: #8c6d1f;
  font-weight: 500;
  flex: 1;
}

.subscribe-guide-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.subscribe-guide-dismiss {
  font-size: 24rpx;
  color: #999;
}

.subscribe-guide-btn {
  font-size: 24rpx;
  color: #fff;
  background: var(--color-primary);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* Quote Card */
.quote-card {
  background: linear-gradient(135deg, #4A90D9, #6BA3E0);
  color: #FFFFFF;
  padding: 40rpx 32rpx;
  border-radius: 16rpx;
}

.quote-text {
  font-size: 30rpx;
  line-height: 1.8;
  margin-bottom: 16rpx;
}

.quote-card .quote-source {
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
  text-align: right;
}

/* Countdown Card */
.countdown-card {
  text-align: center;
  padding: 40rpx 32rpx;
}

.countdown-sections {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
}

.countdown-item {
  flex: 1;
  text-align: center;
}

.countdown-label {
  font-size: 26rpx;
  margin-bottom: 12rpx;
}

.countdown-days {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.countdown-number {
  font-size: 80rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
}

.countdown-unit {
  font-size: 32rpx;
  color: var(--color-primary);
  margin-left: 8rpx;
}

.countdown-divider {
  width: 2rpx;
  height: 80rpx;
  background: var(--color-border);
}

.countdown-hint {
  font-size: 28rpx;
  padding: 20rpx 0;
}

/* Section Card */
.section-card {
  padding: 32rpx;
}

/* Milestone Items */
.milestone-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.milestone-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: var(--color-border);
  margin-right: 20rpx;
  flex-shrink: 0;
}

.milestone-dot.active {
  background-color: var(--color-primary);
  box-shadow: 0 0 0 6rpx var(--color-primary-light);
}

.milestone-info {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.milestone-name {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.milestone-date {
  font-size: 24rpx;
}

/* Quick Entry Grid */
.quick-entries {
  margin-top: 16rpx;
}

.quick-entry-title {
  margin-bottom: 24rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.quick-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #FFFFFF;
  font-weight: 700;
}

.quick-icon-errors {
  background-color: #FF4D4F;
}

.quick-icon-exams {
  background-color: #FAAD14;
}

.quick-icon-growth {
  background-color: #52C41A;
}

.quick-icon-knowledge {
  background-color: #4A90D9;
}

.quick-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.quick-count {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
  margin-top: 4rpx;
}

/* Desktop Guide */
.desktop-guide {
  background: linear-gradient(135deg, #e6f7ff, #bae7ff);
  border: 2rpx solid #69c0ff;
  padding: 24rpx 32rpx;
  margin-top: 16rpx;
}

.desktop-guide-content {
  display: flex;
  align-items: center;
}

.desktop-guide-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.desktop-guide-text {
  font-size: 26rpx;
  color: #096dd9;
  font-weight: 500;
  flex: 1;
}

.desktop-guide-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.desktop-guide-dismiss {
  font-size: 24rpx;
  color: #999;
}

.ai-section {
  margin-top: 16rpx;
}

.ai-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-top: 16rpx;
}

.ai-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 8rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
}

.ai-icon {
  font-size: 40rpx;
}

.ai-label {
  font-size: 22rpx;
  color: #333;
}

.ai-upgrade-card {
  background: linear-gradient(135deg, #f9f0ff, #efdbff);
  border: 2rpx solid #d3adf7;
  margin-top: 16rpx;
  padding: 28rpx 32rpx;
}

.ai-upgrade-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.ai-upgrade-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.ai-upgrade-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #722ed1;
  margin-bottom: 8rpx;
}

.ai-upgrade-desc {
  font-size: 24rpx;
  color: #9254de;
  margin-bottom: 16rpx;
}

.ai-quote-btn {
  margin-top: 12rpx;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #722ed1, #9254de);
  border-radius: 20rpx;
  display: inline-block;
}

.ai-quote-btn text {
  font-size: 22rpx;
  color: #fff;
}

.ai-quote-result {
  margin-top: 16rpx;
  padding: 16rpx;
  background: linear-gradient(135deg, #f9f0ff, #efdbff);
  border-radius: 12rpx;
}

.ai-quote-text {
  font-size: 28rpx;
  color: #531dab;
  line-height: 1.6;
  font-style: italic;
}

.ai-quote-author {
  margin-top: 8rpx;
  text-align: right;
}
