.manage-page {
  padding-bottom: 60rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: var(--font-sm);
  color: var(--color-text-hint);
}

.student-card {
  padding: 24rpx 32rpx;
}

.student-main {
  display: flex;
  align-items: center;
}

.student-info {
  flex: 1;
}

.student-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.student-name {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text-primary);
}

.student-detail {
  display: flex;
  align-items: center;
  margin-top: 4rpx;
}

.student-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 32rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border);
}

.action-btn {
  font-size: var(--font-sm);
  color: var(--color-primary);
  padding: 8rpx 16rpx;
}

.action-danger {
  color: var(--color-error);
}

.add-btn-area {
  margin-top: 32rpx;
}

.editor-header {
  margin-bottom: 24rpx;
}

.form-group {
  margin-bottom: 8rpx;
}

.form-label {
  display: block;
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.form-input {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: var(--font-base);
  color: var(--color-text-primary);
  background-color: #FAFAFA;
}

.form-picker {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: var(--font-base);
  background-color: #FAFAFA;
}

.form-hint {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-hint);
  margin-top: 12rpx;
}

.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.grade-list {
  display: flex;
  gap: 16rpx;
}

.grade-card {
  flex: 1;
  background-color: #FAFAFA;
  border-radius: var(--radius-md);
  padding: 24rpx 16rpx;
  text-align: center;
  border: 3rpx solid transparent;
  transition: all 0.2s;
}

.grade-card-selected {
  border-color: var(--color-primary);
  background-color: var(--color-primary-light);
}

.grade-label {
  display: block;
  font-size: var(--font-md);
  font-weight: 600;
  margin-bottom: 4rpx;
}

.grade-desc {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-hint);
}

.subject-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.subject-chip {
  height: 64rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  font-size: var(--font-sm);
  background-color: #FAFAFA;
  border: 2rpx solid var(--color-border);
  color: var(--color-text-secondary);
  transition: all 0.2s;
}

.subject-chip-selected {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
  color: #FFFFFF;
  font-weight: 600;
}

.editor-footer {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.editor-footer .btn {
  flex: 1;
}
