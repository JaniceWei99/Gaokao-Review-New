.subscription-page {
  padding-bottom: 40rpx;
}

.current-plan {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.plan-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.plan-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.tag-default {
  background: #f0f0f0;
  color: #999;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.trial-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.expire-info {
  margin-top: 8rpx;
}

.plans-section {
  margin-top: 32rpx;
}

.section-title {
  margin-bottom: 20rpx;
}

.plan-card {
  position: relative;
  margin-bottom: 24rpx;
  overflow: visible;
}

.plan-current {
  border-color: var(--color-primary);
  border-width: 2rpx;
  border-style: solid;
}

.plan-popular {
  border-color: var(--color-primary);
  border-width: 2rpx;
  border-style: solid;
}

.plan-card[data-key="premium"] {
  border-color: #722ed1;
  border-width: 2rpx;
  border-style: solid;
  background: linear-gradient(135deg, #fff, #faf5ff);
}

.popular-badge {
  position: absolute;
  top: -16rpx;
  right: 24rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.plan-card-header {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-bottom: 20rpx;
}

.plan-name {
  font-weight: 600;
}

.plan-price {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.plan-desc {
  font-size: 24rpx;
}

.billing-options {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.billing-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 12rpx;
  gap: 4rpx;
}

.billing-selected {
  border-color: var(--color-primary);
  background: rgba(74, 144, 217, 0.08);
}

.billing-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.billing-price {
  font-size: 24rpx;
  font-weight: 600;
}

.billing-save {
  font-size: 20rpx;
  color: #ff6b35;
}

.plan-features {
  margin-bottom: 20rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0;
}

.feature-check {
  color: var(--color-success, #52c41a);
  font-size: 28rpx;
  font-weight: 700;
}

.feature-text {
  font-size: 26rpx;
  color: var(--color-text-primary);
}

.plan-action {
  margin-top: 16rpx;
}

.trial-cta {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  margin-top: 24rpx;
}
