<!-- pages/profile/index.wxml — Profile Page -->
<view class="container profile-page">

  <!-- Guest Visitor Card (not logged in) -->
  <view class="card user-card" wx:if="{{!isLoggedIn}}">
    <view class="user-card-content">
      <view class="user-avatar-placeholder flex-center">
        <text class="avatar-text">{{currentAccountName ? currentAccountName[0] : '访'}}</text>
      </view>
      <view class="user-info">
        <text class="h3">{{currentAccountName || '访客模式'}}</text>
        <text class="caption mt-8">当前账号</text>
      </view>
    </view>
    <view class="user-login-tip">
      <text>未登录状态下数据仅保存在本地手机</text>
    </view>
    <view class="user-login-btn" bindtap="onLogin">
      <text>立即登录 → 数据永不丢失</text>
    </view>
  </view>

  <!-- Logged-in User Card -->
  <view class="card user-card" wx:else>
    <view class="user-card-content">
      <view class="user-avatar">
        <image wx:if="{{userInfo.avatar_url}}" src="{{userInfo.avatar_url}}" class="avatar-image" mode="aspectFill"></image>
        <view wx:else class="user-avatar-placeholder flex-center">
          <text class="avatar-text">{{userInfo.nickname ? userInfo.nickname[0] : 'U'}}</text>
        </view>
      </view>
      <view class="user-info">
        <text class="h3">{{userInfo.nickname || '用户'}}</text>
        <view class="tag tag-primary mt-8">{{planName}}</view>
      </view>
    </view>
  </view>

  <!-- Sync Banner (shown when not logged in but has local data) -->
  <view wx:if="{{!isLoggedIn && hasLocalData}}" class="card sync-banner">
    <view class="sync-banner-content">
      <text class="sync-banner-icon">☁️</text>
      <view class="sync-banner-text">
        <text class="sync-banner-title">有 {{localDataCount}} 条本地数据</text>
        <text class="sync-banner-desc">登录后自动同步到云端，换手机也不丢</text>
      </view>
    </view>
    <text class="btn btn-primary btn-sm" bindtap="onLogin">立即同步</text>
  </view>

  <!-- Local Data Stats (shown when not logged in) -->
  <view wx:if="{{!isLoggedIn && hasLocalData}}" class="card data-stats-card">
    <view class="data-stats-title">本地数据</view>
    <view class="data-stats-grid">
      <view class="data-stat-item">
        <text class="data-stat-num">{{localSummary.examsCount || 0}}</text>
        <text class="data-stat-label">考试成绩</text>
      </view>
      <view class="data-stat-item">
        <text class="data-stat-num">{{localSummary.errorNotesCount || 0}}</text>
        <text class="data-stat-label">错题记录</text>
      </view>
      <view class="data-stat-item">
        <text class="data-stat-num">{{localSummary.growthRecordsCount || 0}}</text>
        <text class="data-stat-label">成长记录</text>
      </view>
    </view>
  </view>

  <!-- Student Info -->
  <view class="card" wx:if="{{currentStudent}}">
    <view class="card-header">
      <text class="card-title">当前学生</text>
      <navigator url="/pages/profile/student-manage" class="btn-text">管理</navigator>
    </view>
    <view class="student-info">
      <text class="body-text">{{currentStudent.name}}</text>
      <text class="caption mt-8">{{currentStudent.grade_display}} · {{currentStudent.district_name}}</text>
      <text class="caption">选考科目：{{currentStudent.elective_display}}</text>
    </view>
  </view>

  <!-- No student prompt -->
  <view class="card add-student-card" wx:if="{{!currentStudent}}">
    <view class="add-student-content">
      <text class="add-student-icon">👶</text>
      <view class="add-student-text">
        <text class="add-student-title">添加孩子信息</text>
        <text class="add-student-desc">设置年级和选考科目，获得个性化建议</text>
      </view>
    </view>
    <navigator url="/pages/onboarding/grade-select" class="btn btn-primary btn-sm">去设置</navigator>
  </view>

  <!-- Settings Links -->
  <view class="card settings-card">
    <navigator url="/pages/profile/student-manage" class="settings-item flex-between">
      <text>学生管理</text>
      <text class="text-hint">></text>
    </navigator>
    <navigator url="/pages/profile/account-switch" class="settings-item flex-between">
      <text>账号切换</text>
      <text class="text-hint">></text>
    </navigator>
    <navigator url="/pages/profile/subscription" class="settings-item flex-between">
      <text>订阅管理</text>
      <text class="text-hint">></text>
    </navigator>
    <view wx:if="{{subscription && subscription.plan === 'premium'}}" class="settings-item flex-between" bindtap="onNavigateTo" data-url="/pages/ai/chat">
      <text>✨ AI家长顾问</text>
      <text class="text-hint">></text>
    </view>
    <view wx:if="{{subscription && subscription.plan === 'premium'}}" class="settings-item flex-between" bindtap="onNavigateTo" data-url="/pages/ai/suggestions">
      <text>💡 AI行动建议</text>
      <text class="text-hint">></text>
    </view>
    <view wx:if="{{subscription && subscription.plan === 'premium'}}" class="settings-item flex-between" bindtap="onNavigateTo" data-url="/pages/ai/monthly-report">
      <text>📊 月度成长报告</text>
      <text class="text-hint">></text>
    </view>
    <view wx:if="{{subscription && subscription.plan !== 'premium'}}" class="settings-item flex-between" bindtap="onUpgradeToPremium">
      <text>✨ 解锁AI助手</text>
      <text class="text-hint premium-hint">高级版 ></text>
    </view>
    <navigator url="/pages/quotes/favorites" class="settings-item flex-between">
      <text>收藏的金句</text>
      <text class="text-hint">></text>
    </navigator>
    <navigator url="/pages/profile/privacy" class="settings-item flex-between">
      <text>隐私设置</text>
      <text class="text-hint">></text>
    </navigator>
    <navigator url="/pages/profile/about" class="settings-item flex-between last">
      <text>关于我们</text>
      <text class="text-hint">></text>
    </navigator>
  </view>

  <!-- Logout Button -->
  <view wx:if="{{isLoggedIn}}" class="mt-24">
    <button class="btn btn-outline btn-block" bindtap="onLogout">退出登录</button>
  </view>

</view>
