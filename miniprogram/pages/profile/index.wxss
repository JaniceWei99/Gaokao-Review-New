/* pages/profile/index.wxss */

.profile-page {
  padding-bottom: 60rpx;
}

/* User Card */
.user-card {
  padding: 32rpx;
}

.user-card-content {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.user-login-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  margin-bottom: 20rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.user-login-btn {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 88rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #67b26f 100%);
  border-radius: 44rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
}

.user-avatar {
  margin-right: 24rpx;
  flex-shrink: 0;
}

.avatar-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.user-avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: var(--color-primary-light);
  margin-right: 24rpx;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 36rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.user-info {
  flex: 1;
}

/* Student Info */
.student-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

/* Settings Card */
.settings-card {
  padding: 0;
}

.settings-item {
  display: flex;
  padding: 32rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  border-bottom: 1rpx solid var(--color-border);
}

.settings-item.last {
  border-bottom: none;
}

.premium-hint {
  color: #722ed1;
  font-weight: 500;
}

/* Sync Banner */
.sync-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #e8f0fe 0%, #d2e3fc 100%);
  padding: 24rpx 28rpx;
}

.sync-banner-content {
  display: flex;
  align-items: center;
  flex: 1;
}

.sync-banner-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.sync-banner-text {
  display: flex;
  flex-direction: column;
}

.sync-banner-title {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 600;
}

.sync-banner-desc {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

/* Data Stats Card */
.data-stats-card {
  padding: 24rpx 28rpx;
}

.data-stats-title {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 20rpx;
  font-weight: 500;
}

.data-stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.data-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.data-stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.data-stat-label {
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

/* Add Student Card */
.add-student-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
}

.add-student-content {
  display: flex;
  align-items: center;
  flex: 1;
}

.add-student-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.add-student-text {
  display: flex;
  flex-direction: column;
}

.add-student-title {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 600;
}

.add-student-desc {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}
