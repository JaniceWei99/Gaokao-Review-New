/* pages/errors/list.wxss */

.errors-page {
  padding-bottom: 120rpx;
}

.stats-bar {
  display: flex;
  overflow-x: auto;
  gap: 24rpx;
  padding: 16rpx 24rpx;
  white-space: nowrap;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 100rpx;
}

.stat-number {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: 4rpx;
}

.filter-bar {
  margin-bottom: 16rpx;
}

.filter-scroll {
  white-space: nowrap;
  padding: 8rpx 24rpx;
}

.filter-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 9999rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background-color: var(--color-card-bg);
}

.filter-item.active {
  color: #FFFFFF;
  background-color: var(--color-primary);
}

.error-card {
  display: block;
  padding: 28rpx;
}

.error-header {
  margin-bottom: 8rpx;
}

.error-type-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  background: #fef3c7;
  color: #92400e;
}

.error-source-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  background: #dbeafe;
  color: #1e40af;
  margin-left: 12rpx;
}

.error-thumb {
  width: 160rpx;
  height: 120rpx;
  border-radius: 8rpx;
}

.error-content {
  line-height: 1.6;
}

.error-footer {
  padding-top: 12rpx;
}

.loading-state {
  text-align: center;
  padding: 80rpx 0;
  color: var(--color-text-tertiary);
  font-size: 28rpx;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 140rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.4);
}

.fab-icon {
  color: #FFFFFF;
  font-size: 48rpx;
  font-weight: 300;
  line-height: 1;
}
