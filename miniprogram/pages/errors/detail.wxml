<!-- pages/errors/detail.wxml -->
<view class="container error-detail-page">

  <view wx:if="{{loading}}" class="loading-state">
    <text>加载中...</text>
  </view>

  <block wx:if="{{!loading && note}}">
    <!-- 题目图片 -->
    <view class="card mb-16" wx:if="{{note.question_image_url}}">
      <view class="card-title mb-8">题目</view>
      <image
        src="{{note.question_image_url}}"
        mode="widthFix"
        class="detail-image"
        bindtap="onPreviewImage"
        data-url="{{note.question_image_url}}"
      ></image>
    </view>

    <!-- 订正图片 -->
    <view class="card mb-16" wx:if="{{note.correction_image_url}}">
      <view class="card-title mb-8">订正</view>
      <image
        src="{{note.correction_image_url}}"
        mode="widthFix"
        class="detail-image"
        bindtap="onPreviewImage"
        data-url="{{note.correction_image_url}}"
      ></image>
    </view>

    <!-- 信息区 -->
    <view class="card mb-16">
      <view class="info-row" wx:if="{{note.subject_id}}">
        <text class="info-label">科目</text>
        <text class="info-value">{{note.subject_name || note.subject_id}}</text>
      </view>
      <view class="info-row" wx:if="{{note.error_type}}">
        <text class="info-label">错误类型</text>
        <text class="info-value">{{note.error_type}}</text>
      </view>
      <view class="info-row" wx:if="{{note.source}}">
        <text class="info-label">来源</text>
        <text class="info-value">{{note.source}}</text>
      </view>
      <view class="info-row" wx:if="{{note.knowledge_node_id}}">
        <text class="info-label">知识点</text>
        <text class="info-value">{{note.knowledge_node_name || note.knowledge_node_id}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">记录时间</text>
        <text class="info-value">{{note.created_at}}</text>
      </view>
    </view>

    <!-- 备注 -->
    <view class="card mb-16" wx:if="{{note.note}}">
      <view class="card-title mb-8">备注</view>
      <text class="note-text">{{note.note}}</text>
    </view>

    <!-- AI Classification -->
    <view class="card mb-16 ai-classify-card">
      <view class="card-title mb-8">🤖 AI错题分类</view>
      <view wx:if="{{!classification && !classifying}}">
        <text class="classify-desc text-secondary">使用AI自动识别错题所属知识点和学习建议</text>
        <view class="btn btn-primary btn-sm mt-12" bindtap="onClassifyWithAI">开始分类</view>
      </view>
      <view wx:if="{{classifying}}" class="classify-loading">
        <text class="classify-loading-icon">🤖</text>
        <text class="classify-loading-text">AI正在分析...</text>
      </view>
      <view wx:if="{{classification}}" class="classify-result">
        <view class="classify-item" wx:if="{{classification.suggested_chapter}}">
          <text class="classify-label">建议章节：</text>
          <text class="classify-value">{{classification.suggested_chapter}}</text>
        </view>
        <view class="classify-item" wx:if="{{classification.suggested_knowledge_points && classification.suggested_knowledge_points.length > 0}}">
          <text class="classify-label">知识点：</text>
          <text class="classify-value">{{classification.suggested_knowledge_points.join('、')}}</text>
        </view>
        <view class="classify-item" wx:if="{{classification.difficulty_assessment}}">
          <text class="classify-label">难度评估：</text>
          <text class="classify-value">{{classification.difficulty_assessment}}</text>
        </view>
        <view class="classify-item" wx:if="{{classification.study_advice}}">
          <text class="classify-label">学习建议：</text>
          <text class="classify-value">{{classification.study_advice}}</text>
        </view>
      </view>
    </view>

    <!-- 删除按钮 -->
    <view class="btn btn-danger btn-block btn-lg mt-24" bindtap="onDelete">删除此错题</view>
  </block>

  <!-- 删除确认弹窗 -->
  <view class="modal-mask" wx:if="{{showDeleteConfirm}}" bindtap="onCancelDelete">
    <view class="modal-content" catchtap="">
      <view class="modal-title">确认删除</view>
      <view class="modal-body">删除后无法恢复，确定要删除这道错题吗？</view>
      <view class="modal-actions">
        <view class="modal-btn modal-btn-cancel" bindtap="onCancelDelete">取消</view>
        <view class="modal-btn modal-btn-danger" bindtap="onConfirmDelete">删除</view>
      </view>
    </view>
  </view>

</view>
