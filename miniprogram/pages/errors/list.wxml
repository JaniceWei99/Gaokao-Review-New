<!-- pages/errors/list.wxml — 错题列表 -->
<view class="container errors-page">

  <!-- 未登录提示 -->
  <view wx:if="{{!isLoggedIn && errorNotes.length > 0}}" class="local-tip card">
    <text class="text-hint">当前为本地数据，登录后可同步到云端</text>
  </view>

  <!-- Stats Summary -->
  <view class="stats-bar" wx:if="{{stats}}">
    <view class="stat-item">
      <text class="stat-number">{{stats.total_count || 0}}</text>
      <text class="stat-label">总错题</text>
    </view>
    <view class="stat-item" wx:for="{{stats.by_subject}}" wx:key="subject_id">
      <text class="stat-number">{{item.count}}</text>
      <text class="stat-label">{{item.subject_name}}</text>
    </view>
  </view>

  <!-- Filter Bar -->
  <view class="filter-bar">
    <scroll-view scroll-x class="filter-scroll">
      <view class="filter-item {{currentSubject === '' ? 'active' : ''}}" bindtap="onFilterSubject" data-subject="">
        全部
      </view>
      <view
        class="filter-item {{currentSubject === item.id ? 'active' : ''}}"
        wx:for="{{subjects}}"
        wx:key="id"
        bindtap="onFilterSubject"
        data-subject="{{item.id}}"
      >
        {{item.name}}
      </view>
    </scroll-view>
  </view>

  <!-- Error Notes List -->
  <view class="error-list">
    <block wx:if="{{errorNotes.length > 0}}">
      <navigator
        class="card error-card"
        wx:for="{{errorNotes}}"
        wx:key="id"
        url="/pages/errors/detail?id={{item.id}}"
      >
        <view class="error-header flex-between">
          <view class="flex-start">
            <view class="error-type-tag" wx:if="{{item.error_type_label}}">{{item.error_type_label}}</view>
            <view class="error-source-tag ml-8" wx:if="{{item.source_label}}">{{item.source_label}}</view>
          </view>
          <text class="subject-tag text-hint">{{item.subject_name}}</text>
        </view>
        <view class="error-content mt-8" wx:if="{{item.question_image_url}}">
          <image src="{{item.question_image_url}}" mode="aspectFill" class="error-thumb"></image>
        </view>
        <view class="error-content mt-8" wx:if="{{item.note}}">
          <text class="body-text">{{item.note}}</text>
        </view>
        <view class="error-footer mt-8 flex-between">
          <text class="caption">{{item.created_at_display}}</text>
        </view>
      </navigator>
    </block>

    <!-- Empty State -->
    <view wx:elif="{{!loading}}" class="empty-state">
      <text class="empty-state-text">还没有错题记录</text>
      <text class="text-hint mt-8" wx:if="{{!isLoggedIn}}">未登录状态下记录的错题会保存在本地</text>
      <view class="btn btn-primary btn-sm mt-16" bindtap="onGoToAdd">记录第一道错题</view>
    </view>

    <!-- Loading -->
    <view wx:if="{{loading}}" class="loading-state">
      <text>加载中...</text>
    </view>
  </view>

  <!-- FAB -->
  <view class="fab" bindtap="onGoToAdd">
    <text class="fab-icon">+</text>
  </view>

</view>
