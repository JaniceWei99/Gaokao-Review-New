.export-page {
  padding-bottom: 40rpx;
}

.section-title {
  margin-bottom: 32rpx;
}

.title-text {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.title-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-hint);
}

.permission-hint {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: rgba(255, 149, 0, 0.06);
  border: 1rpx solid rgba(255, 149, 0, 0.2);
  margin-bottom: 24rpx;
}

.hint-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.hint-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.hint-link {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.form-picker {
  background-color: var(--color-card-bg);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  font-size: var(--font-base);
}

.form-picker-placeholder {
  color: var(--color-text-hint);
}

.export-btn {
  margin-bottom: 32rpx;
}

.preview-section {
  margin-top: 24rpx;
}

.preview-label {
  display: block;
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.preview-image {
  width: 100%;
  border-radius: var(--radius-md);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}
