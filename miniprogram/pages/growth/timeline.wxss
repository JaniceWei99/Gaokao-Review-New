/* pages/growth/timeline.wxss */

.growth-page {
  padding-bottom: 120rpx;
}

.growth-header {
  padding: 8rpx 0;
}

/* Category Scroll */
.category-scroll {
  white-space: nowrap;
  padding: 8rpx 0;
}

.category-scroll .tag {
  display: inline-flex;
  margin-right: 16rpx;
}

/* Timeline */
.timeline {
  position: relative;
  padding-left: 40rpx;
}

.timeline-item {
  position: relative;
  margin-bottom: 32rpx;
}

.timeline-line {
  position: absolute;
  left: -32rpx;
  top: 0;
  bottom: -32rpx;
  width: 2rpx;
  background-color: var(--color-border);
}

.timeline-item:last-child .timeline-line {
  display: none;
}

.timeline-dot {
  position: absolute;
  left: -38rpx;
  top: 28rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background-color: var(--color-primary);
  border: 4rpx solid var(--color-primary-light);
}

.timeline-card {
  margin-left: 8rpx;
}

.timeline-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.timeline-desc {
  font-size: 26rpx;
  line-height: 1.6;
}

.record-image {
  width: 100%;
  height: 300rpx;
  border-radius: 8rpx;
}

/* FAB */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 140rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: var(--color-success);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(82, 196, 26, 0.4);
}

.fab-icon {
  color: #FFFFFF;
  font-size: 48rpx;
  font-weight: 300;
  line-height: 1;
}
