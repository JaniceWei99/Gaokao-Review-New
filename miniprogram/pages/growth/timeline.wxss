/* pages/growth/timeline.wxss */

.growth-page {
  padding-bottom: 120rpx;
}

.growth-header {
  padding: 8rpx 24rpx;
}

.year-scroll {
  white-space: nowrap;
  padding: 8rpx 24rpx;
}

.year-tab {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background: var(--color-card-bg);
}

.year-tab.year-active {
  color: #fff;
  background: var(--color-primary);
}

.type-scroll {
  white-space: nowrap;
  padding: 8rpx 24rpx;
}

.type-scroll .tag {
  display: inline-block;
  margin-right: 16rpx;
}

.timeline {
  position: relative;
  padding-left: 56rpx;
  padding-right: 24rpx;
}

.timeline-item {
  position: relative;
  margin-bottom: 32rpx;
}

.timeline-line {
  position: absolute;
  left: -40rpx;
  top: 0;
  bottom: -32rpx;
  width: 2rpx;
  background-color: var(--color-border);
}

.timeline-item:last-child .timeline-line {
  display: none;
}

.timeline-dot {
  position: absolute;
  left: -46rpx;
  top: 28rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background-color: var(--color-primary);
  border: 4rpx solid var(--color-primary-light);
}

.timeline-card {
  margin-left: 8rpx;
}

.type-badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  background: #dbeafe;
  color: #1e40af;
}

.timeline-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.timeline-desc {
  font-size: 26rpx;
  line-height: 1.6;
}

.awarding-body {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.record-image {
  width: 100%;
  border-radius: 8rpx;
}

.timeline-actions {
  display: flex;
  justify-content: flex-end;
}

.delete-link {
  font-size: 24rpx;
  color: #e53e3e;
  padding: 4rpx 12rpx;
}

.loading-state {
  text-align: center;
  padding: 80rpx 0;
  color: var(--color-text-tertiary);
  font-size: 28rpx;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 140rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: var(--color-success);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(82, 196, 26, 0.4);
}

.fab-icon {
  color: #FFFFFF;
  font-size: 48rpx;
  font-weight: 300;
  line-height: 1;
}
