<!-- pages/growth/timeline.wxml — 成长记录时间线 -->
<view class="container growth-page">

  <!-- Header -->
  <view class="growth-header flex-between mb-16">
    <view>
      <text class="h2">成长记录</text>
      <text class="text-hint ml-8 source-tag" wx:if="{{source === 'local' && !isLoggedIn}}">本地</text>
    </view>
  </view>

  <!-- 未登录提示 -->
  <view wx:if="{{!isLoggedIn && records.length > 0}}" class="local-tip card">
    <text class="text-hint">当前为本地数据，登录后可同步到云端</text>
  </view>

  <!-- School Year Tabs -->
  <scroll-view scroll-x class="year-scroll mb-16" wx:if="{{schoolYears.length > 0}}">
    <view
      class="year-tab {{currentSchoolYear === '' ? 'year-active' : ''}}"
      bindtap="onSwitchSchoolYear"
      data-year=""
    >全部</view>
    <view
      class="year-tab {{currentSchoolYear === item ? 'year-active' : ''}}"
      wx:for="{{schoolYears}}"
      wx:key="*this"
      bindtap="onSwitchSchoolYear"
      data-year="{{item}}"
    >{{item}}</view>
  </scroll-view>

  <!-- Type Filter -->
  <scroll-view scroll-x class="type-scroll mb-16">
    <view
      class="tag {{currentType === '' ? 'tag-selected' : 'tag-outline'}}"
      bindtap="onFilterType"
      data-type=""
    >全部</view>
    <view
      class="tag {{currentType === 'award' ? 'tag-selected' : 'tag-outline'}}"
      bindtap="onFilterType"
      data-type="award"
    >🏆 获奖</view>
    <view
      class="tag {{currentType === 'progress' ? 'tag-selected' : 'tag-outline'}}"
      bindtap="onFilterType"
      data-type="progress"
    >📈 进步</view>
    <view
      class="tag {{currentType === 'performance' ? 'tag-selected' : 'tag-outline'}}"
      bindtap="onFilterType"
      data-type="performance"
    >🎭 演出</view>
    <view
      class="tag {{currentType === 'breakthrough' ? 'tag-selected' : 'tag-outline'}}"
      bindtap="onFilterType"
      data-type="breakthrough"
    >💡 突破</view>
    <view
      class="tag {{currentType === 'memo' ? 'tag-selected' : 'tag-outline'}}"
      bindtap="onFilterType"
      data-type="memo"
    >📝 备忘</view>
  </scroll-view>

  <!-- Timeline -->
  <view class="timeline">
    <block wx:if="{{records.length > 0}}">
      <view class="timeline-item" wx:for="{{records}}" wx:key="id">
        <view class="timeline-line"></view>
        <view class="timeline-dot"></view>
        <view class="card timeline-card">
          <view class="flex-between">
            <text class="type-badge">{{item.type_label}}</text>
            <text class="caption">{{item.date_display}}</text>
          </view>
          <view class="timeline-title mt-8">{{item.title}}</view>
          <view wx:if="{{item.description}}" class="timeline-desc mt-8 text-secondary">
            {{item.description}}
          </view>
          <view wx:if="{{item.awarding_body}}" class="awarding-body mt-8">
            颁奖机构：{{item.awarding_body}}
          </view>
          <view wx:if="{{item.image_url}}" class="timeline-image mt-8">
            <image src="{{item.image_url}}" mode="widthFix" class="record-image"></image>
          </view>
          <view class="timeline-actions mt-8">
            <view class="delete-link" bindtap="onDeleteRecord" data-id="{{item.id}}">删除</view>
          </view>
        </view>
      </view>
    </block>

    <!-- Empty State -->
    <view wx:elif="{{!loading}}" class="empty-state">
      <text class="empty-state-text">还没有成长记录</text>
      <text class="text-hint mt-8" wx:if="{{!isLoggedIn}}">未登录状态下记录的成长瞬间会保存在本地</text>
      <view class="btn btn-primary btn-sm mt-16" bindtap="onGoToAdd">记录第一个成长瞬间</view>
    </view>

    <!-- Loading -->
    <view wx:if="{{loading}}" class="loading-state">
      <text>加载中...</text>
    </view>
  </view>

  <!-- FAB -->
  <view class="fab" bindtap="onGoToAdd">
    <text class="fab-icon">+</text>
  </view>

</view>
