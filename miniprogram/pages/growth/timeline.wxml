<!-- pages/growth/timeline.wxml — Growth Records Timeline -->
<view class="container growth-page">

  <!-- Header -->
  <view class="growth-header flex-between mb-16">
    <text class="h2">成长记录</text>
    <navigator url="/pages/growth/export" class="btn btn-outline btn-sm">导出档案</navigator>
  </view>

  <!-- Category Filter -->
  <scroll-view scroll-x class="category-scroll mb-16">
    <view
      class="tag {{currentCategory === '' ? 'tag-selected' : 'tag-outline'}}"
      bindtap="onFilterCategory"
      data-category=""
    >全部</view>
    <view
      class="tag {{currentCategory === item.key ? 'tag-selected' : 'tag-outline'}}"
      wx:for="{{categories}}"
      wx:key="key"
      bindtap="onFilterCategory"
      data-category="{{item.key}}"
    >{{item.name}}</view>
  </scroll-view>

  <!-- Timeline -->
  <view class="timeline">
    <block wx:if="{{records.length > 0}}">
      <view class="timeline-item" wx:for="{{records}}" wx:key="id">
        <view class="timeline-line"></view>
        <view class="timeline-dot"></view>
        <view class="card timeline-card">
          <view class="flex-between">
            <text class="tag tag-primary">{{item.category_name}}</text>
            <text class="caption">{{item.date_display}}</text>
          </view>
          <view class="timeline-title mt-8">{{item.title}}</view>
          <view wx:if="{{item.description}}" class="timeline-desc mt-8 text-secondary">
            {{item.description}}
          </view>
          <view wx:if="{{item.image_url}}" class="timeline-image mt-8">
            <image src="{{item.image_url}}" mode="aspectFill" class="record-image"></image>
          </view>
        </view>
      </view>
    </block>

    <!-- Empty State -->
    <view wx:else class="empty-state">
      <text class="empty-state-text">还没有成长记录</text>
      <navigator url="/pages/growth/add" class="btn btn-primary btn-sm mt-16">记录第一个成长瞬间</navigator>
    </view>
  </view>

  <!-- Add Button (FAB) -->
  <navigator url="/pages/growth/add" class="fab">
    <text class="fab-icon">+</text>
  </navigator>

</view>
